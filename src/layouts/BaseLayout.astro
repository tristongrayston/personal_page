---
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';
import { withBase } from '../utils/urls';

interface Props {
  title: string;
  description?: string;
  /** When false, the site header is omitted (e.g. homepage hub). Default true. */
  showHeader?: boolean;
  /** Extra classes merged onto `<main>` (layout spacing is always applied). */
  mainClass?: string;
}

const { title, description, showHeader = true, mainClass = '' } = Astro.props;
const siteTitle = 'Triston Grayston';
const pageTitle = title === siteTitle ? title : `${title} · ${siteTitle}`;
const mainTop = showHeader ? 'pt-2' : 'pt-16 sm:pt-24';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    {description ? <meta name="description" content={description} /> : null}
    <ViewTransitions />
  </head>
  <body
    class="min-h-dvh font-sans text-[15px] sm:text-base leading-relaxed text-muted"
  >
    {
      showHeader ? (
        <header class="mx-auto flex max-w-[650px] flex-wrap items-baseline justify-between gap-x-6 gap-y-2 px-5 py-8 sm:py-10">
          <a
            href={withBase('')}
            class="text-sm font-medium tracking-tight text-heading transition-colors duration-200 hover:text-highlight"
          >
            {siteTitle}
          </a>
          <nav aria-label="Primary" class="flex flex-wrap gap-x-6 gap-y-1 text-sm">
            <a
              href={withBase('projects')}
              class="text-muted/90 transition-colors duration-200 hover:text-highlight"
            >
              Projects
            </a>
            <a
              href={withBase('blog')}
              class="text-muted/90 transition-colors duration-200 hover:text-highlight"
            >
              Writings
            </a>
          </nav>
        </header>
      ) : null
    }
    <main
      class:list={[
        'mx-auto max-w-[650px] px-5 pb-20 sm:pb-28',
        mainTop,
        mainClass,
      ]}
    >
      <slot />
    </main>
  </body>
</html>
