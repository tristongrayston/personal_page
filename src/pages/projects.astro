---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/projects';
import { withBase } from '../utils/urls';

function resolvedHref(href: string): string {
  if (/^https?:\/\//i.test(href)) return href;
  return withBase(href.replace(/^\/+/, ''));
}

function isRemote(href: string): boolean {
  return /^https?:\/\//i.test(href);
}
---

<BaseLayout title="Projects" description="Selected projects by Jordan Lee.">
  <div class="space-y-12">
    <header class="space-y-2">
      <h1 class="text-3xl font-semibold tracking-tight text-heading sm:text-4xl">Projects</h1>
      <p class="text-muted">Things I have built or led. External links open in a new tab.</p>
    </header>

    <ul class="divide-y divide-white/10">
      {
        projects.map((project) => (
          <li class="py-10 first:pt-0">
            <a
              href={resolvedHref(project.href)}
              target={isRemote(project.href) ? '_blank' : undefined}
              rel={isRemote(project.href) ? 'noopener noreferrer' : undefined}
              class="group block transition-colors duration-200"
            >
              <h2 class="text-lg font-medium text-highlight transition-colors group-hover:text-[#b2e6d2]">
                {project.title}
              </h2>
              <p class="mt-2 text-muted group-hover:text-muted/90">{project.description}</p>
              <p class="mt-4 text-[0.65rem] uppercase tracking-wider text-muted/75" aria-label="Technologies">
                {project.tags.join(' · ')}
              </p>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>
