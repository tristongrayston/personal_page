---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../utils/urls';

const bio =
  'I am an undergraduate student at the University of Victoria, in my last year studying Mathematics and Computer Science. During my time at the university I have developed my passion for intelligent systems, fascinated by works which use computation to expand, develop, or utilize some form of intelligence. On this website you will see some of the projects I have made over my years as a developer.';

const hubLinks: {
  label: string;
  description: string;
  href: string;
}[] = [
  {
    label: 'Projects',
    description: 'research, coursework, and builds with tags and outbound links',
    href: withBase('projects'),
  },
  {
    label: 'Writings',
    description: 'longer notes and trip logs',
    href: withBase('blog'),
  },
  {
    label: 'Resume',
    description: 'CV and experience at a glance',
    href: withBase('resume'),
  },
  {
    label: 'Contact',
    description: 'email and collaborations',
    href: 'mailto:graystontriston@gmail.com',
  },
];
---

<BaseLayout
  title="Triston Grayston"
  description="Undergraduate Mathematics and Computer Science at the University of Victoria — intelligent systems, reinforcement learning, and software."
  showHeader={false}
>
  <div class="space-y-10 sm:space-y-14">
    <div class="space-y-6">
      <h1 class="text-4xl font-semibold tracking-tight text-heading sm:text-5xl">Triston Grayston</h1>
      <p class="max-w-prose leading-7 text-muted">
        {bio}
      </p>
    </div>

    <nav aria-label="Site sections">
      <ul class="space-y-8">
        {
          hubLinks.map((item) => (
            <li class="leading-7">
              <a href={item.href} class="group block transition-colors duration-200">
                <span class="font-medium text-highlight transition-colors group-hover:text-[#b2e6d2]">
                  {item.label}
                </span>
                <span class="text-muted group-hover:text-muted/90"> — {item.description}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <footer class="border-t border-white/10 pt-10">
      <ul class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-muted">
        <li>
          <a
            href="https://github.com/tristongrayston"
            class="transition-colors duration-200 hover:text-highlight"
            target="_blank"
            rel="noopener noreferrer"
          >
            GitHub
          </a>
        </li>
        <li>
          <a
            href="https://www.linkedin.com/in/triston-grayston-9a3111224"
            class="transition-colors duration-200 hover:text-highlight"
            target="_blank"
            rel="noopener noreferrer"
          >
            LinkedIn
          </a>
        </li>
        <li>
          <a href="mailto:graystontriston@gmail.com" class="transition-colors duration-200 hover:text-highlight">
            Email
          </a>
        </li>
      </ul>
    </footer>
  </div>
</BaseLayout>
