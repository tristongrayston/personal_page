---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { formatDate } from '../../utils/date';
import { slugFromEntryId } from '../../utils/slug';

type BlogPost = CollectionEntry<'blog'>;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: slugFromEntryId(post.id) },
    props: { post },
  }));
}

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="blog-post">
    <header class="space-y-3">
      <time
        datetime={post.data.pubDate.toISOString()}
        class="text-xs uppercase tracking-widest text-muted/80"
      >
        {formatDate(post.data.pubDate)}
      </time>
      <h1 class="text-3xl font-semibold tracking-tight text-heading sm:text-4xl">
        {post.data.title}
      </h1>
      <p class="text-muted">{post.data.description}</p>
    </header>
    <div class="blog-post-body">
      <Content />
    </div>
  </article>
</BaseLayout>

<style is:global>
  .blog-post-body {
    margin-top: 2.5rem;
    color: var(--color-muted);
    font-size: 0.9375rem;
    line-height: 1.75;
  }
  .blog-post-body > :global(* + *) {
    margin-top: 1.25rem;
  }
  .blog-post-body :global(a) {
    color: var(--color-highlight);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: filter 200ms ease, opacity 200ms ease;
  }
  .blog-post-body :global(a:hover) {
    color: #b2e6d2;
  }
  .blog-post-body :global(strong) {
    color: var(--color-heading);
    font-weight: 600;
  }
</style>
